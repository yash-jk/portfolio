    "use": "@vercel/static-build",
    "config": {
      "distDir": "build"
    }
  },
  "dependencies": {
    "framer-motion": "^12.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.4.0",
